# Example Terminai / mprocs configuration
# Copy to mprocs.yaml and customize

# Process definitions (optional - can also use CLI args)
procs:
  shell:
    shell: "$SHELL"

# Optional: custom keybindings
# keymap_procs:
#   "<C-space>": { c: toggle-ai }

# Optional: UI settings
# hide_keymap_window: false
# proc_list_width: 30
# scrollback: 1000
# mouse_scroll_speed: 5
